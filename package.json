{
  "name": "dashboard",
  "version": "0.0.0",
  "description": "Dashboard for LizardByte",
  "scripts": {
    "test": "npm-run-all test:unit test:report test:lint",
    "test:unit": "jest --coverage",
    "test:report": "jest --reporters=jest-junit",
    "test:lint": "eslint gh-pages-template/assets/js/**/*.js tests/**/*.js",
    "lint": "eslint gh-pages-template/assets/js/**/*.js tests/**/*.js",
    "lint:fix": "eslint gh-pages-template/assets/js/**/*.js tests/**/*.js --fix"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {},
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/tests/**/*.spec.js"
    ],
    "collectCoverageFrom": [
      "gh-pages-template/assets/js/*.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 100,
        "lines": 100
      }
    }
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.2",
    "@eslint/js": "10.0.1",
    "@jest/globals": "30.3.0",
    "babel-jest": "30.3.0",
    "eslint": "10.2.0",
    "globals": "17.4.0",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "jest-junit": "16.0.0",
    "npm-run-all": "4.1.5"
  }
}
